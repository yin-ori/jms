---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCurrentlyReading, getReadBooks, groupByYear } from '@/utils/goodreads';

const locale = 'de';
const title = 'Lesen';
const description = 'Was ich gerade lese und in den letzten Jahren gelesen habe';

const currentYear = new Date().getFullYear();
const [current, read] = await Promise.all([getCurrentlyReading(), getReadBooks()]);
const years = groupByYear(read);

const formatDay = (d: Date) =>
  d.toLocaleDateString('de-DE', { day: 'numeric', month: 'long' });
const formatMonth = (d: Date) =>
  d.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' });
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  keywords={['lesen', 'bücher', 'leseliste', 'literatur']}
>
  <div class="min-h-screen bg-warm-50 dark:bg-dark-50">
    <div class="max-w-2xl mx-auto px-6 py-16">
      <!-- Header -->
      <div class="mb-16">
        <h1 class="text-2xl font-medium text-warm-900 dark:text-dark-900">Lesen</h1>
      </div>

      {current.length > 0 && (
        <section class="mb-12">
          <h2 class="text-lg font-medium text-warm-900 dark:text-dark-900 mb-6 pb-2 border-b border-warm-300 dark:border-dark-300">
            Gerade lese ich
          </h2>
          {current.map((book) => (
            <div class="current flex gap-6 items-start mb-6 last:mb-0">
              {book.cover && (
                <a href={book.link} target="_blank" rel="noopener">
                  <img class="current-cover" src={book.cover} alt={`Cover: ${book.title}`} width="106" loading="eager" />
                </a>
              )}
              <div>
                <p class="current-title text-warm-900 dark:text-dark-900">{book.title}</p>
                <p class="text-warm-600 dark:text-dark-600 mb-4">{book.author}</p>
                {book.addedAt && (
                  <p class="current-since text-warm-500 dark:text-dark-500 text-sm italic">seit {formatMonth(book.addedAt)}</p>
                )}
                <div class="current-rule"></div>
              </div>
            </div>
          ))}
        </section>
      )}

      {years.map(([year, books]) => (
        <details class="year mb-5" open={year === currentYear}>
          <summary class="text-lg font-medium text-warm-900 dark:text-dark-900 pb-2 border-b border-warm-300 dark:border-dark-300">
            <span class="chev" aria-hidden="true"></span>
            Gelesen {year}
            <span class="count text-warm-500 dark:text-dark-500 text-sm font-normal">{books.length}</span>
          </summary>
          <ul class="mt-2">
            {books.map((book) => (
              <li class="row flex gap-4 items-center py-3.5">
                {book.cover && (
                  <img class="thumb" src={book.cover} alt={`Cover: ${book.title}`} width="42" height="62" loading="lazy" />
                )}
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-warm-800 dark:text-dark-800 leading-snug">
                    <a href={book.link} target="_blank" rel="noopener" class="hover:text-warm-600 dark:hover:text-dark-600 transition-colors">{book.title}</a>
                  </p>
                  <p class="text-warm-500 dark:text-dark-500 text-sm">{book.author}</p>
                </div>
                <div class="row-meta">
                  <span class="text-warm-500 dark:text-dark-500 text-xs tabular-nums">{formatDay(book.readAt!)}</span>
                  {book.rating > 0 && (
                    <span class="dots" title={`${book.rating} von 5`}>
                      {Array.from({ length: 5 }, (_, i) => (
                        <span class={i < book.rating ? 'dot f' : 'dot'}></span>
                      ))}
                    </span>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </details>
      ))}

      {years.length === 0 && current.length === 0 && (
        <p class="text-warm-600 dark:text-dark-600">
          Die Leseliste konnte gerade nicht geladen werden — schau bald wieder vorbei.
        </p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .current-cover {
    flex-shrink: 0;
    border-radius: 3px;
    box-shadow: 0 3px 14px rgba(28, 25, 23, 0.14);
    filter: saturate(0.65) sepia(0.1) contrast(0.95);
    transition: filter 0.25s ease;
  }
  .current-cover:hover { filter: none; }
  :global(.dark) .current-cover { box-shadow: 0 3px 14px rgba(0, 0, 0, 0.5); }

  .current-title {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.375rem;
    line-height: 1.35;
    margin: 0.25rem 0;
    text-wrap: balance;
  }
  .current-since { font-family: 'Lora', Georgia, serif; }
  .current-rule {
    height: 1px;
    width: 3.5rem;
    margin-top: 1rem;
    background: linear-gradient(to right, #bfaedc, transparent);
    opacity: 0.6;
  }
  :global(.dark) .current-rule {
    background: linear-gradient(to right, #7d6ba2, transparent);
  }

  .year summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .year summary::-webkit-details-marker { display: none; }
  .year summary:focus-visible {
    outline: 2px solid #7d6ba2;
    outline-offset: 3px;
    border-radius: 2px;
  }
  .chev {
    width: 0.5rem;
    height: 0.5rem;
    flex-shrink: 0;
    border-right: 1.5px solid #a8a29d;
    border-bottom: 1.5px solid #a8a29d;
    transform: rotate(-45deg);
    transition: transform 0.18s ease;
    margin-top: -2px;
  }
  :global(.dark) .chev { border-color: #6b6560; }
  .year[open] .chev { transform: rotate(45deg); margin-top: -5px; }
  .count { margin-left: auto; }

  .year ul { list-style: none; margin: 0; padding: 0; }
  .row + .row { border-top: 1px solid rgba(0, 0, 0, 0.05); }
  :global(.dark) .row + .row { border-top-color: rgba(255, 255, 255, 0.05); }

  .thumb {
    width: 42px;
    height: 62px;
    object-fit: cover;
    border-radius: 2px;
    box-shadow: 0 1px 5px rgba(28, 25, 23, 0.14);
    flex-shrink: 0;
    filter: saturate(0.65) sepia(0.1) contrast(0.95);
    transition: filter 0.25s ease;
  }
  .row:hover .thumb { filter: none; }
  :global(.dark) .thumb { box-shadow: 0 1px 5px rgba(0, 0, 0, 0.5); }

  .row-meta {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    align-items: flex-end;
  }
  .dots { display: inline-flex; gap: 3px; }
  .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #e3e0db;
  }
  :global(.dark) .dot { background: #3a352c; }
  .dot.f { background: #7d6ba2; opacity: 0.7; }
  :global(.dark) .dot.f { background: #bfaedc; }

  @media (prefers-reduced-motion: reduce) {
    .chev, .thumb, .current-cover { transition: none; }
  }
</style>
